# Application Settings
APP_NAME=Aviva Intelligent Mail
APP_ENV=development
DEBUG=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aim_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_RETRIES=3

# OpenRouter (for dev/testing)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embeddings (for vector store)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=openai

# Vector Store
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=aim_documents
CHROMA_PERSIST_DIRECTORY=./chroma_data

# Security
SECRET_KEY=change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Privacy
ENABLE_PII_REDACTION=true
PII_REDACTION_PLACEHOLDERS=true
REDACTION_CONFIDENCE_THRESHOLD=0.7

# Audit
AUDIT_LOG_LEVEL=INFO
AUDIT_RETENTION_DAYS=90

# Stageflow
ENABLE_STAGEFLOW_TRACING=true
STAGEFLOW_CORRELATION_ID_HEADER=X-Correlation-ID

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
MAX_REQUEST_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# Evaluation
GOLDEN_DATASET_PATH=./eval/dataset
EVAL_OUTPUT_PATH=./eval/results
REGRESSION_TRACKING=true
