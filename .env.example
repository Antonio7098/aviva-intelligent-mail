# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aviva_claims

# ChromaDB
CHROMA_URL=http://localhost:8001

# LLM Settings
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# Application
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# Security - DO NOT enable in production
ENABLE_RAW_LOGGING=false
